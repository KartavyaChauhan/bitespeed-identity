{
  "info": {
    "name": "Bitespeed Identity API",
    "description": "API collection for testing Bitespeed Identity Reconciliation endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Check if the API is running"
      }
    },
    {
      "name": "New Customer - Email + Phone",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"lorraine@hillvalley.edu\",\n  \"phoneNumber\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/identify",
          "host": ["{{baseUrl}}"],
          "path": ["identify"]
        },
        "description": "Create a new primary contact with both email and phone"
      }
    },
    {
      "name": "New Customer - Email Only",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"newuser@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/identify",
          "host": ["{{baseUrl}}"],
          "path": ["identify"]
        },
        "description": "Create a new contact with email only"
      }
    },
    {
      "name": "New Customer - Phone Only",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phoneNumber\": \"9876543210\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/identify",
          "host": ["{{baseUrl}}"],
          "path": ["identify"]
        },
        "description": "Create a new contact with phone only"
      }
    },
    {
      "name": "Existing Contact - Same Phone, New Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"mcfly@hillvalley.edu\",\n  \"phoneNumber\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/identify",
          "host": ["{{baseUrl}}"],
          "path": ["identify"]
        },
        "description": "Query with existing phone but new email. Should create secondary contact."
      }
    },
    {
      "name": "Existing Contact - Email Only Match",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"lorraine@hillvalley.edu\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/identify",
          "host": ["{{baseUrl}}"],
          "path": ["identify"]
        },
        "description": "Query with only email that exists in system"
      }
    },
    {
      "name": "Existing Contact - Phone Only Match",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phoneNumber\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/identify",
          "host": ["{{baseUrl}}"],
          "path": ["identify"]
        },
        "description": "Query with only phone that exists in system"
      }
    },
    {
      "name": "Error - Missing Email and Phone",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": null,\n  \"phoneNumber\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/identify",
          "host": ["{{baseUrl}}"],
          "path": ["identify"]
        },
        "description": "Invalid request - should return 400 error"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ]
}
