{
  "name": "bitespeed-identity",
  "version": "1.0.0",
  "description": "Bitespeed Identity Reconciliation Backend - Customer identity tracking across multiple purchases",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate && tsc",
    "postinstall": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:reset": "npx prisma migrate reset",
    "db:studio": "npx prisma studio"
  },
  "keywords": ["bitespeed", "identity", "reconciliation", "customer"],
  "author": "Bitespeed Developer",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "express": "^5.2.1",
    "prisma": "^5.17.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
